# Keep the real key in .env only. Never put it in frontend or extension code.
ARTIFICIAL_INTELLIGENCE_PROVIDER=openai
ARTIFICIAL_INTELLIGENCE_API_KEY=your-provider-key-here
ARTIFICIAL_INTELLIGENCE_MODEL=gpt-5.4-mini

# Optional: use this for OpenAI-compatible providers that expose /chat/completions.
# ARTIFICIAL_INTELLIGENCE_PROVIDER=openai-compatible
# ARTIFICIAL_INTELLIGENCE_BASE_URL=https://api.example.com/v1

API_PORT=8787
